# ============================================
# AI CROP ADVISORY PLATFORM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Application Name
APP_NAME=AI Crop Advisory Platform

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB connection string
# Format: mongodb://localhost:27017/dbname
# or for MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URL=mongodb://localhost:27017/agri_advisor_dev

# Database name (dev or prod)
DB_NAME=agri_advisor_dev

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Secret Keys (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
ACCESS_TOKEN_SECRET=your_access_token_secret_here_min_32_characters
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_min_32_characters

# Admin Account (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_secure_password

# ============================================
# EXTERNAL API KEYS
# ============================================

# OpenWeather API Key (REQUIRED for real-time weather data)
# Get your free API key at: https://openweathermap.org/api
# Used by: Backend weather fetcher, Frontend weather service
OPENWEATHER_API_KEY=your_openweather_api_key_here

# AI/ML API Key (REQUIRED for backend API authentication)
# Used by: Frontend to authenticate with backend irrigation/soil/pest endpoints
# Generate a secure random string: openssl rand -hex 32
AIMLAPI_AI_API_KEY=your_aimlapi_key_here_min_32_characters

# LocationIQ API Key (Optional - for geocoding)
# Get your API key at: https://locationiq.com/
LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# Agro Monitoring API Key (Optional - for satellite soil data)
# Get your API key at: https://agromonitoring.com/
AGROMONITORING_API_KEY=your_agromonitoring_api_key_here

# OpenAI API Key (Optional - for advanced AI features)
# Get your API key at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
# SMTP settings for sending emails (password resets, notifications, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password

# ============================================
# FRONTEND-ONLY VARIABLES (Vite - VITE_ prefix required)
# ============================================
# These variables are used by the React frontend
# They must start with VITE_ to be accessible in the browser

# Backend API URL (where the Express server is running)
VITE_API_BASE_URL=http://localhost:5000/api

# OpenWeather API Key (for frontend weather service)
# NOTE: This should ideally be the same as OPENWEATHER_API_KEY above
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# AI/ML API Key (for frontend to backend authentication)
# NOTE: This should match AIMLAPI_AI_API_KEY above
VITE_AIMLAPI_AI_API_KEY=your_aimlapi_key_here_min_32_characters

# LocationIQ API Key (Optional)
VITE_LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# Agro Monitoring API Key (Optional)
VITE_AGROMONITORING_API_KEY=your_agromonitoring_api_key_here

# OpenAI API Key (Optional)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# SETUP INSTRUCTIONS
# ============================================
#
# 1. REQUIRED API KEYS (Get these first):
#    - OPENWEATHER_API_KEY: Sign up at https://openweathermap.org/api (FREE)
#    - AIMLAPI_AI_API_KEY: Generate with: openssl rand -hex 32
#
# 2. GENERATE SECURE JWT SECRETS:
#    Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    Use the output for JWT_SECRET, ACCESS_TOKEN_SECRET, REFRESH_TOKEN_SECRET
#
# 3. DATABASE SETUP:
#    - Install MongoDB locally OR use MongoDB Atlas (cloud)
#    - Update MONGODB_URL with your connection string
#
# 4. EMAIL SETUP (Optional - for notifications):
#    - For Gmail: Enable 2FA and generate an App Password
#    - Update SMTP_HOST, SMTP_USER, SMTP_PASS
#
# 5. COPY CONFIGURATION:
#    - Copy this file: cp .env.example .env
#    - Fill in your actual values in .env
#    - NEVER commit .env to git!
#
# ============================================
# SECURITY NOTES
# ============================================
# - NEVER commit .env file to version control
# - Use strong, randomly generated secrets for JWT
# - Rotate API keys regularly
# - Use different keys for development and production
# - Keep .env file permissions restricted (chmod 600 .env)
# - Use environment variable management tools in production (e.g., AWS Secrets Manager, HashiCorp Vault)
#
# ============================================
# VERIFICATION
# ============================================
# After setup, verify your configuration:
# 1. Backend: npm run server (should start without errors)
# 2. Frontend: npm run dev (should connect to backend)
# 3. Test weather API: Open app and check weather data loads
# 4. Test irrigation API: Navigate to Irrigation page and submit a query
